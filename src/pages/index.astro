---
import { getCollection } from 'astro:content';
import MainLayout from '../layouts/MainLayout.astro';
import HeroSection from '../components/sections/HeroSection.astro';
import ReelSection from '../components/sections/ReelSection.astro';
import WorkGridSection from '../components/sections/WorkGridSection.astro';
import AboutSection from '../components/sections/AboutSection.astro';

const works = (await getCollection('works')).sort((a, b) => a.data.order - b.data.order);

const personalWorks = works.filter((work) => work.data.category === 'personal');
const commercialWorks = works.filter((work) => work.data.category === 'commercial');
const toolWorks = works.filter((work) => work.data.category === 'tool');
---

<MainLayout>
	<HeroSection />
	<ReelSection />
	<WorkGridSection
		id="selected-work"
		eyebrow="Selected Personal Work"
		title="Selected FX Shots"
		copy="Houdini-based simulation work including RBD, FLIP, and Pyro."
		works={personalWorks}
		variant="featured"
	/>
	<WorkGridSection
		id="commercial-work"
		eyebrow="Commercial Work"
		title="Production and HDA Work"
		copy="Selected contributions to production projects, including HDA-driven workflows."
		works={commercialWorks}
		variant="compact"
	/>
	<WorkGridSection
		id="tool-work"
		eyebrow="Tool / R&D"
		title="Tool Development and R&D"
		copy="Procedural tools and technical experiments supporting FX workflows."
		works={toolWorks}
		variant="spotlight"
	/>
	<AboutSection />
</MainLayout>

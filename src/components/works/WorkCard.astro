---
import type { CollectionEntry } from 'astro:content';

interface Props {
	work: CollectionEntry<'works'>;
	variant?: 'featured' | 'compact' | 'spotlight';
}

const { work, variant = 'featured' } = Astro.props;
const { data, id } = work;
const tags = [...data.software, ...data.techniques];
---

<article class:list={['work-card', `work-card-${variant}`, `work-card-${data.category}`]}>
	<a class="work-card-link" href={`/works/${id}/`}>
		<div class="work-card-image">
			<img src={data.thumbnail.src} alt={data.title} loading="lazy" />
		</div>
		<div class="work-card-body">
			<p class="detail-label">{data.category}</p>
			{data.subtitle && <p class="work-subtitle">{data.subtitle}</p>}
			<h3 class="work-card-title">{data.title}</h3>
			<p class="work-card-summary">{data.summary}</p>
			<ul class="tag-list">
				{tags.map((item) => <li>{item}</li>)}
			</ul>
		</div>
	</a>
</article>

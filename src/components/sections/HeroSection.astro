---
import { site } from '../../data/site';
import HeroBackground from '../../assets/Personal/back2.png';
---

<section class="hero-section" style={`--hero-image: url(${HeroBackground.src})`}>
	<div class="hero-copy">
		<p class="hero-eyebrow">{site.role}</p>
		<h1>{site.title}</h1>
		<p class="hero-focus">{site.focus}</p>
		<p class="hero-summary">
			Creating cinematic-scale FX (RBD, FLIP, Pyro) with a focus on efficient, production-ready workflows and tool development.
		</p>
		<div class="hero-actions">
			<a class="button button-primary" href="#demoreel">Watch Demo Reel</a>
			<a class="button button-secondary" href="#selected-work">Explore Work</a>
		</div>
	</div>
	<div class="hero-panel">
		<p class="hero-panel-label">Skills</p>
		<ul class="hero-list">
			<li>RBD/FLIP/Pyro</li>
			<li>VEX/Python</li>
			<li>Procedural modeling</li>
			<li>HDA Development</li>
		</ul>
	</div>
</section>

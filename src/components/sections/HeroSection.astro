---
import { site } from '../../data/site';
---

<section class="hero-section">
	<div class="hero-copy">
		<p class="hero-eyebrow">{site.role}</p>
		<h1>{site.title}</h1>
		<p class="hero-focus">{site.focus}</p>
		<p class="hero-summary">
			FX Artist focused on Houdini simulations, including RBD, FLIP, and Pyro, with an emphasis on cinematic scale and procedural workflows.
		</p>
		<div class="hero-actions">
			<a class="button button-primary" href="#demoreel">Watch Demo Reel</a>
			<a class="button button-secondary" href="#selected-work">View Selected Work</a>
		</div>
	</div>
	<div class="hero-panel">
		<p class="hero-panel-label">Selected Work</p>
		<ul class="hero-list">
			<li>Selected personal FX work</li>
			<li>Commercial and HDA projects</li>
			<li>Tool-driven R&amp;D work</li>
		</ul>
	</div>
</section>

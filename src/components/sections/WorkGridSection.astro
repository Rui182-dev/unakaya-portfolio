---
import SectionHeader from './SectionHeader.astro';
import WorkCard from '../works/WorkCard.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
	id: string;
	eyebrow: string;
	title: string;
	copy: string;
	works: CollectionEntry<'works'>[];
	variant?: 'featured' | 'compact' | 'spotlight';
}

const { id, eyebrow, title, copy, works, variant = 'featured' } = Astro.props;
const isFeatured = variant === 'featured';
const showFeaturedArrows = isFeatured && works.length > 3;
const isToolCarousel = isFeatured && works.length > 0 && works.every((work) => work.data.category === 'tool');
---

<section id={id} class:list={["content-section", `content-section-${variant}`]}>
	<SectionHeader eyebrow={eyebrow} title={title} copy={copy} />
	<div class:list={['featured-carousel-shell', !isFeatured && 'featured-carousel-shell-mobile', isToolCarousel && 'featured-carousel-shell-single']}>
		{showFeaturedArrows && (
			<button class="carousel-button carousel-button-prev" type="button" aria-label="Scroll left" data-carousel-prev={id}>
				<span aria-hidden="true">&larr;</span>
			</button>
		)}
		<div
			class:list={['work-grid', `work-grid-${variant}`, isToolCarousel && 'work-grid-featured-single']}
			data-carousel-row={id}
			data-carousel-variant={variant}
		>
			{
				works.map((work) => (
					<WorkCard work={work} variant={variant} />
				))
			}
		</div>
		{showFeaturedArrows && (
			<button class="carousel-button carousel-button-next" type="button" aria-label="Scroll right" data-carousel-next={id}>
				<span aria-hidden="true">&rarr;</span>
			</button>
		)}
		<div class="carousel-dots" aria-label="Featured work pages" data-carousel-dots={id}></div>
		{works.length > 1 && <div class="carousel-swipe-hint" aria-hidden="true" data-carousel-hint={id}>Swipe</div>}
	</div>
</section>

<script is:inline>
	(() => {
		const initCarousels = () => {
			const rows = document.querySelectorAll('[data-carousel-row]');
			const mobileQuery = window.matchMedia('(max-width: 720px)');

			rows.forEach((row) => {
				if (row.dataset.carouselReady === 'true') return;
				row.dataset.carouselReady = 'true';

				const id = row.getAttribute('data-carousel-row');
				const variant = row.getAttribute('data-carousel-variant') ?? 'featured';
				const prev = document.querySelector(`[data-carousel-prev="${id}"]`);
				const next = document.querySelector(`[data-carousel-next="${id}"]`);
				const dots = document.querySelector(`[data-carousel-dots="${id}"]`);
				const hint = document.querySelector(`[data-carousel-hint="${id}"]`);
				const shell = row.closest('.featured-carousel-shell');
				const cards = Array.from(row.children);
				const isToolDesktopSingle = row.classList.contains('work-grid-featured-single');
				let activeIndex = 0;
				let touchStartX = 0;
				let touchDeltaX = 0;

				const isMobileSingleCardMode = () => mobileQuery.matches;
				const isDesktopCarousel = () => variant === 'featured' && !isToolDesktopSingle;
				const isDesktopSingleCardMode = () => !mobileQuery.matches && isToolDesktopSingle;
				const isSingleCardMode = () => isMobileSingleCardMode() || isDesktopSingleCardMode();
				const usesCarousel = () => isSingleCardMode() || isDesktopCarousel();

				const getDesktopPageCount = () => Math.max(1, Math.round(row.scrollWidth / row.clientWidth));

				const syncSingleCardState = () => {
					if (!isSingleCardMode()) {
						cards.forEach((card) => card.classList.remove('is-carousel-hidden'));
						return;
					}

					cards.forEach((card, index) => {
						card.classList.toggle('is-carousel-hidden', index !== activeIndex);
					});
				};

				const renderDots = () => {
					if (!dots) return;
					if (!usesCarousel()) {
						dots.innerHTML = '';
						return;
					}

					dots.innerHTML = '';
					const pageCount = isSingleCardMode() ? Math.max(1, cards.length) : getDesktopPageCount();
					const currentIndex = isSingleCardMode()
						? activeIndex
						: (() => {
							const maxScroll = Math.max(1, row.scrollWidth - row.clientWidth);
							return Math.min(pageCount - 1, Math.round((row.scrollLeft / maxScroll) * (pageCount - 1)));
						})();

					for (let index = 0; index < pageCount; index += 1) {
						const dot = document.createElement('button');
						dot.type = 'button';
						dot.className = `carousel-dot${index === currentIndex ? ' is-active' : ''}`;
						dot.setAttribute('aria-label', `Go to page ${index + 1}`);
						dot.addEventListener('click', () => goToPage(index));
						dots.appendChild(dot);
					}
				};

				const goToPage = (index) => {
					if (isSingleCardMode()) {
						activeIndex = Math.max(0, Math.min(cards.length - 1, index));
						syncSingleCardState();
						renderDots();
						return;
					}

					if (!isDesktopCarousel()) return;

					const pageCount = getDesktopPageCount();
					row.scrollTo({
						left: (row.scrollWidth - row.clientWidth) * (index / Math.max(1, pageCount - 1)),
						behavior: 'smooth',
					});
				};

				const resetSwipeOffset = () => {
					row.style.removeProperty('--mobile-swipe-offset');
					row.classList.remove('is-dragging');
				};

				const hideHint = () => {
					if (cards.length <= 1) return;
					shell?.classList.add('is-swipe-hint-hidden');
					hint?.setAttribute('hidden', 'true');
				};

				const syncMode = () => {
					activeIndex = Math.max(0, Math.min(cards.length - 1, activeIndex));
					resetSwipeOffset();
					syncSingleCardState();
					renderDots();
				};

				prev?.addEventListener('click', () => {
					if (isSingleCardMode()) {
						goToPage(activeIndex - 1);
						return;
					}

					if (!isDesktopCarousel()) return;

					const pageCount = getDesktopPageCount();
					const maxScroll = Math.max(1, row.scrollWidth - row.clientWidth);
					const activePage = Math.min(pageCount - 1, Math.round((row.scrollLeft / maxScroll) * (pageCount - 1)));
					goToPage(activePage - 1);
				});

				next?.addEventListener('click', () => {
					if (isSingleCardMode()) {
						goToPage(activeIndex + 1);
						return;
					}

					if (!isDesktopCarousel()) return;

					const pageCount = getDesktopPageCount();
					const maxScroll = Math.max(1, row.scrollWidth - row.clientWidth);
					const activePage = Math.min(pageCount - 1, Math.round((row.scrollLeft / maxScroll) * (pageCount - 1)));
					goToPage(activePage + 1);
				});

				row.addEventListener('touchstart', (event) => {
					if (!isSingleCardMode()) return;
					touchStartX = event.changedTouches[0]?.clientX ?? 0;
					touchDeltaX = 0;
					row.classList.add('is-dragging');
					hideHint();
				}, { passive: true });

				row.addEventListener('touchmove', (event) => {
					if (!isSingleCardMode()) return;
					touchDeltaX = (event.changedTouches[0]?.clientX ?? 0) - touchStartX;
					const clampedOffset = Math.max(-36, Math.min(36, touchDeltaX * 0.35));
					row.style.setProperty('--mobile-swipe-offset', `${clampedOffset}px`);
				}, { passive: true });

				row.addEventListener('touchend', () => {
					if (!isSingleCardMode()) return;
					const movedEnough = Math.abs(touchDeltaX) >= 40;
					resetSwipeOffset();
					if (movedEnough) {
						goToPage(activeIndex + (touchDeltaX < 0 ? 1 : -1));
					}
					touchDeltaX = 0;
				}, { passive: true });

				row.addEventListener('touchcancel', () => {
					resetSwipeOffset();
					touchDeltaX = 0;
				}, { passive: true });

				if (isDesktopCarousel()) {
					row.addEventListener('scroll', () => {
						window.requestAnimationFrame(renderDots);
					});
				}

				mobileQuery.addEventListener('change', syncMode);
				window.addEventListener('resize', renderDots);
				syncMode();
			});
		};

		if (document.readyState === 'loading') {
			document.addEventListener('DOMContentLoaded', initCarousels, { once: true });
		} else {
			initCarousels();
		}
	})();
</script>
